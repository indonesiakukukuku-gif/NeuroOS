    // --- NEUROLANG: EMOTIONAL RESONANCE ---
    // Mengukur frekuensi emosional untuk distribusi harian
    fn calculate_aura(stress: Float, kindness: Float) -> Float {
        // Algoritma E-KINDNESS: 0-10 coin reward per hari
        // Sesuai kesepakatan: Reward berdasarkan aktivitas media estafet
        let daily_reward = (kindness * 10.0) - (stress * 0.27);
        return daily_reward.clamp(0, 10);
    }

    // --- AURALANG: LOCKING MECHANISM ---
    // Founder lock 3 thn, General lock 2 thn
    fn check_lock_status(identity: TM_Identity, years_passed: Int) -> Bool {
        if (identity.is_founder) {
            return years_passed < 3; 
        }
        return years_passed < 2;
    }

